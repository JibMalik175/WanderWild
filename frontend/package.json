{
  "name": "wanderwild-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:api": "node ../scripts/test-api-endpoints.js",
    "test:api:local": "API_BASE_URL=http://localhost:3001/api node ../scripts/test-api-endpoints.js",
    "test:api:staging": "API_BASE_URL=https://staging-api.wanderwild.com/api node ../scripts/test-api-endpoints.js",
    "test:api:production": "API_BASE_URL=https://api.wanderwild.com/api node ../scripts/test-api-endpoints.js",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:integration": "npm run test:api && npm run test && npm run test:e2e",
    "test:all": "npm run test:integration",
    "validate:env": "node scripts/validate-environment.js",
    "check:api-connectivity": "node scripts/check-api-connectivity.js"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "axios": "^1.6.0",
    "framer-motion": "^10.16.0",
    "lucide-react": "^0.294.0",
    "next": "14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.65.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^13.4.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/sinonjs__fake-timers": "^15.0.0",
    "@types/sizzle": "^2.3.10",
    "autoprefixer": "^10.4.21",
    "colors": "^1.4.0",
    "cypress": "^13.6.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapping": {
      "^@/(.*)$": "<rootDir>/$1"
    },
    "collectCoverageFrom": [
      "app/**/*.{js,jsx,ts,tsx}",
      "!app/**/*.d.ts",
      "!app/**/layout.tsx",
      "!app/**/loading.tsx",
      "!app/**/error.tsx"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  }
}
